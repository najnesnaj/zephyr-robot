<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ebamk2">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import ebamk2 urdf file -->
    <xacro:include filename="/urdf/ebamk2_mesh.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="ebamk2.ros2_control.xacro" />


    <xacro:ebamk2_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
